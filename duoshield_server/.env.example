# ─── Firebase Admin ────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON key file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# OR embed the JSON inline as a single-line string (for Render env vars):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Shared secret that the Flutter app sends in /mintToken requests.
# Choose any long random string, e.g.: openssl rand -hex 32
AUTH_SECRET=replace_with_your_secret_here

# ─── Cloudflare TURN ──────────────────────────────────────────────────────────
# Get these from: Cloudflare Dashboard → Zero Trust → TURN
CLOUDFLARE_TURN_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_TURN_KEY_ID=your_turn_key_id
# TTL for generated credentials in seconds (default 86400 = 24h)
TURN_TTL=86400

# ─── Backblaze B2 (S3-compatible) ─────────────────────────────────────────────
# Create an application key in B2 Console with Read+Write access to your bucket
B2_KEY_ID=your_b2_application_key_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_NAME=your_bucket_name
# B2 S3-compatible endpoint, format: https://s3.<region>.backblazeb2.com
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# Presigned URL TTL in seconds (default 3600 = 1h)
B2_PRESIGN_TTL=3600

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
